// Test config for PREPARE_REFERENCE.
//
// nf-test passes: -c nextflow.config -c <this file> -params-file params.json
// Nextflow deep-merges nested param blocks, so we must override every individual
// key from refdata.config to point at fixture stubs — setting the map to [:] does
// not replace the block-syntax definitions from the project config.

params {
    ref_data_path   = "${projectDir}/subworkflows/local/tests/prepare_reference/fixtures/base"
    data_versions   = [umccr_reference_data: '0']

    genome {
        fasta = 'genome/genome.fa'
        fai   = 'genome/genome.fa.fai'
        dict  = 'genome/genome.fa.dict'
    }

    // Override miscdata_paths — will be further overridden per-test via params {}
    miscdata_paths {
        pcgr_dir    = 'pcgr_dir'
        vep_dir     = 'stub_dir'
        snpeff_dir  = 'stub_dir'
        oncokb_genes = 'stub'
        appris      = 'stub'
        pon_dir     = 'stub_dir'
    }

    // Override every hmfdata_paths key to point at fixture stubs
    hmfdata_paths {
        // Files → stub
        heterozygous_sites          = 'stub'
        gc_profile                  = 'stub'
        diploid_bed                 = 'stub'
        sv_prep_blocklist           = 'stub'
        gridss_pon_breakends        = 'stub'
        gridss_pon_breakpoints      = 'stub'
        repeatmasker_annotations    = 'stub'
        isofox_counts               = 'stub'
        isofox_gc_ratios            = 'stub'
        clinvar_annotations         = 'stub'
        sage_blocklist_regions      = 'stub'
        sage_highconf_regions       = 'stub'
        sage_known_hotspots_somatic = 'stub'
        sage_pon                    = 'stub'
        virus_reporting_db          = 'stub'
        virus_taxonomy_db           = 'stub'
        gridss_config               = 'stub'
        purple_germline_del         = 'stub'
        segment_mappability         = 'stub'
        // Directories → stub_dir
        cuppa_resources             = 'stub_dir'
        gnomad_resource             = 'stub_dir'
    }

    // Override every umccrdata_paths key to point at fixture stubs
    umccrdata_paths {
        // Files → stub
        somatic_panel                      = 'stub'
        somatic_panel_genes                = 'stub'
        somatic_panel_genes_ts             = 'stub'
        somatic_panel_regions_gene         = 'stub'
        somatic_panel_regions_cds          = 'stub'
        known_fusion_pairs                 = 'stub'
        known_fusion_five                  = 'stub'
        known_fusion_three                 = 'stub'
        germline_panel_genes               = 'stub'
        germline_panel_regions_transcript  = 'stub'
        hotspots                           = 'stub'
        driver_gene_panel                  = 'stub'
        sage_known_hotspots_germline       = 'stub'
        known_fusions                      = 'stub'
        known_fusion_data                  = 'stub'
        purple_baf_circos_config           = 'stub'
        purple_baf_circos_gaps             = 'stub'
        // Directories → stub_dir
        annotations_dir                    = 'stub_dir'
        ensembl_data_resources             = 'stub_dir'
    }
}

manifest {
    name            = 'nextflow_workflow'
    nextflowVersion = '!>=23.04.0'
}
