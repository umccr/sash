nextflow_workflow {

    name "Test Workflow PREPARE_INPUT"
    script "subworkflows/local/prepare_input.nf"
    workflow "PREPARE_INPUT"
    config "subworkflows/local/tests/prepare_input/nextflow.config"
    tag "subworkflows/local/prepare_input"

    test("OA-only: emits all channels and resolves PAVE germline") {

        when {
            workflow {
                """
                def base = file("${projectDir}/subworkflows/local/tests/prepare_input/fixtures/default")
                def ss   = file("${launchDir}/samplesheet.csv")
                ss.text  = [
                    "id,subject_name,sample_name,filetype,filepath,tumor_id,normal_id",
                    "TEST_01,SUBJECT_01,,oncoanalyser_dir,\${base}/oncoanalyser_dir,TUMOR,NORMAL",
                ].join("\\n")
                input[0] = ss
                """
            }
        }

        then {
            assert workflow.success

            with(workflow.out.sage_somatic) {
                assert size() == 1
                with(get(0)) {
                    assert get(1).toString().endsWith("TUMOR.sage.somatic.vcf.gz")
                    assert get(2).toString().endsWith("TUMOR.sage.somatic.vcf.gz.tbi")
                }
            }

            with(workflow.out.vcf_germline) {
                assert size() == 1
                with(get(0)) {
                    // oncoanalyser names the PAVE germline VCF by tumor_id, not normal_id
                    assert get(1).toString().endsWith("TUMOR.pave.germline.vcf.gz")
                }
            }
        }
    }
}
